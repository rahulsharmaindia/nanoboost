NODE_ENV=development
PORT=3000
SERVER_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database (Supabase Postgres)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Instagram / Meta OAuth
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
REDIRECT_URI=

# AI (Google Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Meta App Dashboard Configuration ─────────────────────────
# These are NOT consumed by the server code. They are reference
# values you enter in the Meta App Dashboard during App Review.
#
# Privacy Policy URL:         https://your-server.com/privacy-policy
# Terms of Service URL:       https://your-server.com/terms-of-service
# Data Deletion Callback URL: https://your-server.com/api/meta/deletion-callback
#
# Future (not yet implemented):
# META_WEBHOOK_VERIFY_TOKEN=
