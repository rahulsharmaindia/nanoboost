{{! Subject: Your {{tierName}} plan is scheduled to cancel on {{effectiveDate}} }}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cancellation Scheduled — NanoCeleb</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1a1a1a; }
    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { background: #718096; padding: 32px 40px; text-align: center; }
    .header h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; letter-spacing: -0.3px; }
    .body { padding: 40px; }
    .greeting { font-size: 16px; color: #333333; margin-bottom: 24px; }
    .info-box { background: #f7fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 24px; margin-bottom: 32px; }
    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #edf2f7; font-size: 15px; }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: #666666; }
    .info-value { color: #1a1a1a; font-weight: 500; }
    .message { font-size: 15px; color: #555555; line-height: 1.6; margin-bottom: 24px; }
    .access-note { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 16px 20px; font-size: 14px; color: #166534; margin-bottom: 32px; }
    .cta-group { text-align: center; margin: 32px 0; }
    .cta-primary { display: inline-block; background: #6C47FF; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 600; margin-bottom: 12px; }
    .cta-secondary { display: block; font-size: 14px; color: #6C47FF; text-decoration: none; margin-top: 12px; }
    .footer { background: #f5f5f5; padding: 24px 40px; text-align: center; font-size: 13px; color: #999999; }
    .footer a { color: #6C47FF; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>NanoCeleb</h1>
    </div>

    <div class="body">
      <p class="greeting">Hi {{userName}},</p>

      <p class="message">
        We've received your cancellation request for the <strong>{{tierName}}</strong> plan.
        Your subscription will remain active until the end of your current billing period.
      </p>

      <div class="info-box">
        <div class="info-row">
          <span class="info-label">Plan</span>
          <span class="info-value">{{tierName}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Access ends</span>
          <span class="info-value">{{effectiveDate}}</span>
        </div>
      </div>

      <div class="access-note">
        <strong>You keep full access until {{effectiveDate}}.</strong> After that, your account moves to the free Creator tier automatically — no further charges.
      </div>

      <p class="message">
        Changed your mind? You can resume your subscription anytime before {{effectiveDate}} and nothing will change.
      </p>

      <div class="cta-group">
        <a class="cta-primary" href="https://nanoceleb.com/app/manage-subscription">Resume subscription</a>
        <a class="cta-secondary" href="https://nanoceleb.com/app/plans">Explore plans</a>
      </div>
    </div>

    <div class="footer">
      <p>© NanoCeleb · <a href="https://nanoceleb.com">nanoceleb.com</a></p>
      <p>You're receiving this because you have an active NanoCeleb subscription.</p>
    </div>
  </div>
</body>
</html>
