{{! Subject: Your NanoCeleb subscription has lapsed }}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Subscription Lapsed — NanoCeleb</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1a1a1a; }
    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { background: #E53E3E; padding: 32px 40px; text-align: center; }
    .header h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; letter-spacing: -0.3px; }
    .body { padding: 40px; }
    .greeting { font-size: 16px; color: #333333; margin-bottom: 24px; }
    .status-box { background: #fff5f5; border: 1px solid #fed7d7; border-radius: 10px; padding: 24px; margin-bottom: 32px; text-align: center; }
    .status-box .status-label { font-size: 13px; color: #999999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .status-box .status-value { font-size: 18px; font-weight: 700; color: #E53E3E; }
    .message { font-size: 15px; color: #555555; line-height: 1.6; margin-bottom: 24px; }
    .what-changed { background: #f7fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 24px; margin-bottom: 32px; }
    .what-changed h3 { margin: 0 0 16px; font-size: 14px; color: #666666; text-transform: uppercase; letter-spacing: 0.5px; }
    .change-item { display: flex; align-items: flex-start; gap: 10px; padding: 6px 0; font-size: 14px; color: #555555; }
    .change-item::before { content: "•"; color: #E53E3E; font-weight: 700; flex-shrink: 0; }
    .cta { text-align: center; margin: 32px 0; }
    .cta a { display: inline-block; background: #6C47FF; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 600; }
    .footer { background: #f5f5f5; padding: 24px 40px; text-align: center; font-size: 13px; color: #999999; }
    .footer a { color: #6C47FF; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>NanoCeleb</h1>
    </div>

    <div class="body">
      <p class="greeting">Hi {{userName}},</p>

      <p class="message">
        Unfortunately, we were unable to process your payment after multiple attempts,
        and your <strong>{{previousTier}}</strong> subscription has lapsed.
        Your account has been moved to the free Creator tier.
      </p>

      <div class="status-box">
        <div class="status-label">Previous plan</div>
        <div class="status-value">{{previousTier}}</div>
      </div>

      <div class="what-changed">
        <h3>What's changed</h3>
        <div class="change-item">Your account is now on the free Creator tier</div>
        <div class="change-item">Paid-tier features are no longer accessible</div>
        <div class="change-item">Your usage counters have been reset</div>
        <div class="change-item">No further charges will be made</div>
      </div>

      <p class="message">
        You can resubscribe anytime to regain access to your previous features.
        Update your payment method and choose a plan to get back on track.
      </p>

      <div class="cta">
        <a href="https://nanoceleb.com/app/plans">Resubscribe now</a>
      </div>
    </div>

    <div class="footer">
      <p>© NanoCeleb · <a href="https://nanoceleb.com">nanoceleb.com</a></p>
      <p>You're receiving this because you have a NanoCeleb account.</p>
    </div>
  </div>
</body>
</html>
