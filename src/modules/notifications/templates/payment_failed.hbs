{{! Subject: Action needed — payment failed for your {{tierName}} plan }}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Failed — NanoCeleb</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1a1a1a; }
    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { background: #E53E3E; padding: 32px 40px; text-align: center; }
    .header h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; letter-spacing: -0.3px; }
    .header .icon { font-size: 36px; margin-bottom: 8px; }
    .body { padding: 40px; }
    .greeting { font-size: 16px; color: #333333; margin-bottom: 24px; }
    .alert-box { background: #fff5f5; border: 1px solid #fed7d7; border-radius: 10px; padding: 24px; margin-bottom: 32px; }
    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #fee2e2; font-size: 15px; }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: #666666; }
    .info-value { color: #1a1a1a; font-weight: 500; }
    .message { font-size: 15px; color: #555555; line-height: 1.6; margin-bottom: 24px; }
    .grace-note { background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 16px 20px; font-size: 14px; color: #92400e; margin-bottom: 32px; }
    .cta { text-align: center; margin: 32px 0; }
    .cta a { display: inline-block; background: #E53E3E; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 600; }
    .footer { background: #f5f5f5; padding: 24px 40px; text-align: center; font-size: 13px; color: #999999; }
    .footer a { color: #6C47FF; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="icon">⚠️</div>
      <h1>NanoCeleb</h1>
    </div>

    <div class="body">
      <p class="greeting">Hi {{userName}},</p>

      <p class="message">
        We weren't able to process your payment for the <strong>{{tierName}}</strong> plan.
        Please update your payment method to keep your subscription active.
      </p>

      <div class="alert-box">
        <div class="info-row">
          <span class="info-label">Plan</span>
          <span class="info-value">{{tierName}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Amount</span>
          <span class="info-value">{{amount}} {{currency}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Next retry</span>
          <span class="info-value">{{retryDate}}</span>
        </div>
      </div>

      <div class="grace-note">
        <strong>You still have access.</strong> We'll retry your payment automatically.
        If all retries fail, your plan will revert to the free Creator tier.
      </div>

      <p class="message">
        Update your payment method now to avoid any interruption to your plan.
      </p>

      <div class="cta">
        <a href="https://nanoceleb.com/app/manage-subscription">Update payment method</a>
      </div>
    </div>

    <div class="footer">
      <p>© NanoCeleb · <a href="https://nanoceleb.com">nanoceleb.com</a></p>
      <p>You're receiving this because you have an active NanoCeleb subscription.</p>
    </div>
  </div>
</body>
</html>
