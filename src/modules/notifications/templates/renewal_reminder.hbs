{{! Subject: Your {{tierName}} plan renews on {{renewalDate}} }}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Renewal Reminder — NanoCeleb</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1a1a1a; }
    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { background: #6C47FF; padding: 32px 40px; text-align: center; }
    .header h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; letter-spacing: -0.3px; }
    .body { padding: 40px; }
    .greeting { font-size: 16px; color: #333333; margin-bottom: 24px; }
    .info-box { background: #f9f7ff; border: 1px solid #e0d9ff; border-radius: 10px; padding: 24px; margin-bottom: 32px; }
    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #ede9ff; font-size: 15px; }
    .info-row:last-child { border-bottom: none; font-weight: 700; font-size: 16px; color: #6C47FF; }
    .info-label { color: #666666; }
    .info-value { color: #1a1a1a; font-weight: 500; }
    .message { font-size: 15px; color: #555555; line-height: 1.6; margin-bottom: 24px; }
    .cta { text-align: center; margin: 32px 0; }
    .cta a { display: inline-block; background: #6C47FF; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 600; }
    .footer { background: #f5f5f5; padding: 24px 40px; text-align: center; font-size: 13px; color: #999999; }
    .footer a { color: #6C47FF; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>NanoCeleb</h1>
    </div>

    <div class="body">
      <p class="greeting">Hi {{userName}},</p>

      <p class="message">
        Just a heads-up — your <strong>{{tierName}}</strong> plan is set to renew in 3 days.
        We'll automatically charge your payment method on file.
      </p>

      <div class="info-box">
        <div class="info-row">
          <span class="info-label">Plan</span>
          <span class="info-value">{{tierName}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Renewal date</span>
          <span class="info-value">{{renewalDate}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Currency</span>
          <span class="info-value">{{currency}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Amount</span>
          <span class="info-value">{{amount}}</span>
        </div>
      </div>

      <p class="message">
        Want to make changes before renewal? You can upgrade, downgrade, or cancel anytime from your subscription settings.
      </p>

      <div class="cta">
        <a href="https://nanoceleb.com/app/manage-subscription">Manage subscription</a>
      </div>
    </div>

    <div class="footer">
      <p>© NanoCeleb · <a href="https://nanoceleb.com">nanoceleb.com</a></p>
      <p>You're receiving this because you have an active NanoCeleb subscription.</p>
    </div>
  </div>
</body>
</html>
